ONBID_SERVICE_KEY=
MOLIT_SERVICE_KEY=
KAKAO_REST_KEY=
# 정비사업(호재)은 MOLIT_SERVICE_KEY(공공데이터포털 키)를 재사용합니다.
DATABASE_URL=sqlite+aiosqlite:///./data/auction.db
CORS_ORIGINS=*
HOST=0.0.0.0
PORT=8001

# Analysis document store: local | s3 | r2 | memory
ANALYSIS_DOC_STORE=local
ANALYSIS_DOC_ROOT=./data/analysis_docs
# S3-compatible (AWS / Cloudflare R2 / MinIO)
# ANALYSIS_DOC_STORE=s3
# ANALYSIS_S3_BUCKET=
# ANALYSIS_S3_PREFIX=analysis-docs
# ANALYSIS_S3_REGION=auto
# ANALYSIS_S3_ENDPOINT_URL=   # R2: https://<accountid>.r2.cloudflarestorage.com
# ANALYSIS_S3_ACCESS_KEY=
# ANALYSIS_S3_SECRET_KEY=

# Optional: require X-API-Key on analysis write APIs (empty = open)
# ANALYSIS_API_KEY=
